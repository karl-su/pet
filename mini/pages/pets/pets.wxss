/* pages/pets/pets.wxss */
.container {
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  background-color: white;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.pet-count {
  font-size: 24rpx;
  color: #999;
}

.pets-list {
  flex: 1;
  padding: 20rpx;
}

.pet-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
}

.pet-avatar {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 60rpx;
  background-color: #f0f0f0;
}

.pet-info {
  flex: 1;
  margin-right: 20rpx;
}

.pet-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.pet-type {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.pet-description {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.pet-details {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.detail-item {
  font-size: 22rpx;
  color: #666;
  background-color: #f8f8f8;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.pet-status {
  margin-top: 10rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.status-tag.healthy {
  background-color: #e8f5e8;
  color: #3cc51f;
}

.status-tag.sick {
  background-color: #ffe8e8;
  color: #ff4444;
}

.pet-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  width: 100rpx;
  height: 50rpx;
  font-size: 22rpx;
  border-radius: 25rpx;
  border: none;
  outline: none;
}

.edit-btn {
  background-color: #007aff;
  color: white;
}

.delete-btn {
  background-color: #ff4444;
  color: white;
}

.action-btn:active {
  opacity: 0.8;
}

.add-pet-btn {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
}

.add-pet-btn:active {
  background-color: #f8f8f8;
}

.add-icon {
  font-size: 60rpx;
  color: #3cc51f;
  margin-bottom: 10rpx;
}

.add-text {
  font-size: 28rpx;
  color: #666;
}
