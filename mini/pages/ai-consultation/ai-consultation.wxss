/* pages/ai-consultation/ai-consultation.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.header {
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.header-left {
  display: flex;
  align-items: center;
  cursor: pointer;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
  margin-right: 10rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.header-title {
  flex: 1;
  text-align: center;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  cursor: pointer;
}

.clear-text {
  font-size: 28rpx;
  color: #ff4444;
}

/* 对话内容区域 */
.chat-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.messages-list {
  padding-bottom: 20rpx;
}

.message-item {
  margin-bottom: 30rpx;
}

/* AI消息样式 */
.ai-message {
  display: flex;
  justify-content: flex-start;
}

.ai-content {
  display: flex;
  align-items: flex-start;
  max-width: 80%;
}

.ai-avatar {
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ai-avatar .avatar-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 用户消息样式 */
.user-message {
  display: flex;
  justify-content: flex-end;
}

.user-content {
  display: flex;
  align-items: flex-start;
  max-width: 80%;
  flex-direction: row-reverse;
}

.user-avatar {
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.user-avatar .avatar-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 消息内容 */
.message-body {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.ai-message .message-body {
  background-color: #fff;
}

.user-message .message-body {
  background-color: #95ec69;
}

.message-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-wrap: break-word;
}

.message-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 10rpx;
  margin-top: 15rpx;
  display: block;
}

.message-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
  text-align: right;
}

/* 底部输入区域 */
.input-area {
  background-color: #fff;
  padding: 20rpx;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.image-btn {
  width: 70rpx;
  height: 70rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
}

.image-btn:active {
  background-color: #e8e8e8;
}

.image-icon {
  font-size: 36rpx;
}

.message-input {
  flex: 1;
  height: 70rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 35rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn:active {
  opacity: 0.8;
}

.send-btn[disabled] {
  background-color: #ccc;
  opacity: 0.5;
}