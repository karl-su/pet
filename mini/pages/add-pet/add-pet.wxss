/* pages/add-pet/add-pet.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.form-container {
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-header {
  background-color: #3cc51f;
  padding: 30rpx;
  text-align: center;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.form-content {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #eee;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #eee;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  border: 1rpx solid #eee;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  background-color: #f8f8f8;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 15rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
}

.form-actions {
  padding: 30rpx;
  background-color: #f8f8f8;
}

.save-btn {
  width: 100%;
  height: 80rpx;
  background-color: #3cc51f;
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  outline: none;
}

.save-btn:active {
  background-color: #2ba015;
}
